# Database
DATABASE_URL="postgresql://user:password@localhost:5432/blog_keyword_db"

# Redis (Upstash or local)
REDIS_URL="redis://localhost:6379"

# Google (Trends / Ads API)
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""

# Naver DataLab
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_TRENDS_KEYWORDS="삼성,아이폰,주식,날씨,부동산"

# App base URL (build-time/server fetch)
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# Naver Search Ad API
NAVER_SEARCHAD_API_KEY=""
NAVER_SEARCHAD_SECRET_KEY=""
NAVER_SEARCHAD_CUSTOMER_ID=""

# Feature flags (true/false)
# 네이버 실시간 검색어 순위 (기본 켜짐, false로 끄기)
NAVER_REALTIME_ENABLED="true"
DAUM_ENABLED="false"
BING_ENABLED="false"

# Score weights (0-1, should sum to 1.0)
SCORE_WEIGHT_VOLUME="0.25"
SCORE_WEIGHT_TREND="0.25"
SCORE_WEIGHT_COMPETITION="0.25"
SCORE_WEIGHT_GROWTH="0.25"

# Optional: normalization caps for scoring
SCORE_VOLUME_CAP="100000"
SCORE_TREND_CAP="100"
SCORE_COMPETITION_CAP="1"
